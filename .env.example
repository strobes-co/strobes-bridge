# Strobes Shell Bridge Agent Configuration
# Copy to .env and fill in your values

# Required
STROBES_URL=https://app.strobes.co
STROBES_API_KEY=your-api-key-here
STROBES_ORG_ID=your-org-uuid-here

# Optional
# STROBES_BRIDGE_ID=auto-generated-if-not-set
# STROBES_SHELL_NAME=my-server
# STROBES_CWD=/home/user
# STROBES_VERBOSE=true

# --- Sandbox pack (pre-installed security tools + Python runtime) ---
# The pack (nmap, nuclei + nuclei-templates, httpx, ffuf, gobuster, subfinder, dnsx and
# a full Python with boto3/reportlab/curl_cffi/cryptography) ships INSIDE the artifact:
# baked into the Docker image and embedded in the standalone binary — nothing to install,
# no runtime download, works offline. These are optional overrides only:
# STROBES_PACK_DISABLE=1                               # ignore the pack; use only host tools
# STROBES_PACK_PATH=/opt/strobes-pack/linux-x86_64    # point at a specific pre-extracted pack
# STROBES_PACK_URL=https://github.com/strobes-co/strobes-bridge/releases/download/pack-v0.1.0
#                                                     # optional: fetch a pack if none is bundled
