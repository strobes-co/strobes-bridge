{
  "//": "Static CLI security tools shipped in the pack's bin/ dir. build_pack.py resolves each",
  "//2": "entry for the target (os,arch), downloads it, extracts the named binary, and records",
  "//3": "the observed sha256 into tools.lock.json for reproducible offline verification.",
  "//4": "URL templates use {version} {os} {arch} {arch2}; per-tool os/arch maps normalise naming.",
  "//5": "A tool with no build for a given (os,arch) is skipped (logged), never fatal.",
  "os_map_default": { "linux": "linux", "macos": "macos", "windows": "windows" },
  "arch_map_default": { "x86_64": "amd64", "aarch64": "arm64" },
  "tools": [
    {
      "name": "nuclei",
      "version": "3.6.2",
      "archive": "zip",
      "binary": "nuclei",
      "url": "https://github.com/projectdiscovery/nuclei/releases/download/v{version}/nuclei_{version}_{os}_{arch}.zip",
      "os_map": { "linux": "linux", "macos": "macOS", "windows": "windows" },
      "platforms": ["linux/x86_64", "linux/aarch64", "macos/aarch64", "macos/x86_64", "windows/x86_64"]
    },
    {
      "name": "httpx",
      "version": "1.6.9",
      "archive": "zip",
      "binary": "httpx",
      "url": "https://github.com/projectdiscovery/httpx/releases/download/v{version}/httpx_{version}_{os}_{arch}.zip",
      "os_map": { "linux": "linux", "macos": "macOS", "windows": "windows" },
      "platforms": ["linux/x86_64", "linux/aarch64", "macos/aarch64", "macos/x86_64", "windows/x86_64"]
    },
    {
      "name": "subfinder",
      "version": "2.6.8",
      "archive": "zip",
      "binary": "subfinder",
      "url": "https://github.com/projectdiscovery/subfinder/releases/download/v{version}/subfinder_{version}_{os}_{arch}.zip",
      "os_map": { "linux": "linux", "macos": "macOS", "windows": "windows" },
      "platforms": ["linux/x86_64", "linux/aarch64", "macos/aarch64", "macos/x86_64", "windows/x86_64"]
    },
    {
      "name": "dnsx",
      "version": "1.2.2",
      "archive": "zip",
      "binary": "dnsx",
      "url": "https://github.com/projectdiscovery/dnsx/releases/download/v{version}/dnsx_{version}_{os}_{arch}.zip",
      "os_map": { "linux": "linux", "macos": "macOS", "windows": "windows" },
      "platforms": ["linux/x86_64", "linux/aarch64", "macos/aarch64", "macos/x86_64", "windows/x86_64"]
    },
    {
      "name": "ffuf",
      "version": "2.1.0",
      "archive": "tar.gz",
      "archive_map": { "windows": "zip" },
      "binary": "ffuf",
      "url": "https://github.com/ffuf/ffuf/releases/download/v{version}/ffuf_{version}_{os}_{arch}.{ext}",
      "os_map": { "linux": "linux", "macos": "macos", "windows": "windows" },
      "platforms": ["linux/x86_64", "linux/aarch64", "macos/aarch64", "macos/x86_64", "windows/x86_64"]
    },
    {
      "name": "gobuster",
      "version": "3.6.0",
      "archive": "tar.gz",
      "archive_map": { "windows": "zip" },
      "binary": "gobuster",
      "url": "https://github.com/OJ/gobuster/releases/download/v{version}/gobuster_{os}_{arch2}.{ext}",
      "os_map": { "linux": "Linux", "macos": "Darwin", "windows": "Windows" },
      "platforms": ["linux/x86_64", "linux/aarch64", "macos/aarch64", "macos/x86_64", "windows/x86_64"]
    },
    {
      "name": "nmap",
      "version": "7.94SVN",
      "archive": "tar.gz",
      "kind": "bundle",
      "expose": "link",
      "//": "Linux: ernw portable nmap is musl-static (runs on ANY Linux incl. Alpine/old-",
      "//2": "glibc, no floor). Flat archive: nmap/ncat/nping + data/. NMAPDIR -> data.",
      "//3": "Connect scan (-sT) unprivileged; SYN (-sS)/OS-detect need root/cap_net_raw.",
      "url": "https://github.com/ernw/static-toolbox/releases/download/nmap-v{version}/nmap-{version}-{arch3}-portable.tar.gz",
      "arch3": { "x86_64": "x86_64", "aarch64": "aarch64" },
      "bundle_dir": "nmap",
      "binaries": ["nmap", "ncat", "nping"],
      "primary": "nmap",
      "env": { "NMAPDIR": "share/nmap/data" },
      "platforms": ["linux/x86_64", "linux/aarch64"]
    },
    {
      "name": "nmap",
      "version": "7.92",
      "archive": "zip",
      "kind": "bundle",
      "expose": "path",
      "//": "Windows: last portable win32 zip (nmap stopped shipping it after 7.92). nmap.exe",
      "//2": "needs its adjacent DLLs, so the whole dir goes on PATH (not symlinked out).",
      "//3": "Data files at bundle root -> NMAPDIR=share/nmap. Connect scans (-sT) work; SYN/",
      "//4": "OS-detect need the Npcap driver, a privileged kernel install nmap can't bundle.",
      "url": "https://nmap.org/dist/nmap-{version}-win32.zip",
      "bundle_dir": "nmap",
      "binaries": ["nmap", "ncat", "nping"],
      "primary": "nmap",
      "env": { "NMAPDIR": "share/nmap" },
      "platforms": ["windows/x86_64"]
    },
    {
      "name": "nmap",
      "version": "7.94",
      "archive": "dmg",
      "kind": "dmg",
      "expose": "link",
      "//": "macOS: upstream ships only a .dmg installer. The builder mounts it, expands the",
      "//2": "mpkg and extracts nmap/ncat/nping + data. The binary is x86_64 (native on Intel,",
      "//3": "Rosetta 2 on Apple Silicon) and statically links all but libSystem/libc++.",
      "//4": "Connect scan (-sT) works unprivileged; SYN/OS-detect need sudo. Built on macOS only.",
      "url": "https://nmap.org/dist/nmap-{version}.dmg",
      "bundle_dir": "nmap",
      "components": ["nmap", "ncat", "nping"],
      "binaries": ["nmap", "ncat", "nping"],
      "primary": "nmap",
      "data_from": "share/nmap",
      "env": { "NMAPDIR": "share/nmap/data" },
      "platforms": ["macos/x86_64", "macos/aarch64"]
    },
    {
      "name": "responder",
      "kind": "git",
      "//": "LLMNR/NBT-NS/mDNS poisoner. Git-only (no pip package). internal-ad profile,",
      "//2": "*nix only (needs raw sockets). Deps (netifaces etc.) come from the AD wheels.",
      "repo": "https://github.com/lgandx/Responder.git",
      "ref": "master",
      "bundle_dir": "responder",
      "entry": { "responder": "Responder.py", "responder-dumphash": "tools/DumpHash.py" },
      "profiles": ["internal-ad"],
      "platforms": ["linux/x86_64", "linux/aarch64", "macos/aarch64", "macos/x86_64"]
    },
    {
      "name": "enum4linux-ng",
      "kind": "git",
      "//": "SMB/LDAP/RPC enumeration. Single script, git-only. internal-ad profile.",
      "repo": "https://github.com/cddmp/enum4linux-ng.git",
      "ref": "master",
      "bundle_dir": "enum4linux-ng",
      "entry": { "enum4linux-ng": "enum4linux-ng.py" },
      "profiles": ["internal-ad"],
      "platforms": ["linux/x86_64", "linux/aarch64", "macos/aarch64", "macos/x86_64"]
    }
  ]
}
