# Strobes Shell Bridge Agent Configuration
# Copy to .env and fill in your values

# Required
STROBES_URL=https://app.strobes.co
STROBES_API_KEY=your-api-key-here
STROBES_ORG_ID=your-org-uuid-here

# Optional
# STROBES_BRIDGE_ID=auto-generated-if-not-set
# STROBES_SHELL_NAME=my-server
# STROBES_CWD=/home/user
# STROBES_VERBOSE=true

# --- Sandbox pack (pre-installed security tools + Python runtime) ---
# On startup the bridge auto-downloads the pack matching this host's OS/arch and
# runs nmap, nuclei, httpx, ffuf, gobuster, subfinder, dnsx + a full Python
# (boto3, reportlab, curl_cffi, cryptography, …) from it — no local install needed.
STROBES_PACK_URL=https://github.com/strobes-co/strobes-bridge/releases/download/pack-v0.1.0
# STROBES_PACK_PATH=/opt/strobes-pack/linux-x86_64   # air-gapped: point at a pre-extracted pack
# STROBES_PACK_DIR=~/.strobes-shell-agent/pack        # where downloaded packs are cached
# STROBES_PACK_DISABLE=1                               # opt out; use only host-installed tools
